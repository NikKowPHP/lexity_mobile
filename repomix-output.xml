    final newGoals = UserGoals(
      weeklyActivities: _weeklyActivities,
      dailyStudyGoalInMinutes: int.tryParse(_dailyGoalController.text) ?? 15,
      maxNewPerDay: int.tryParse(_maxNewController.text) ?? 20,
